% Required packages
\usepackage[backend=bibtex, style=authoryear, backref=true, maxcitenames=2]{biblatex}
\addbibresource{references.bib}
%
% Gray citation color
\usepackage{xcolor}
\definecolor{mygray}{gray}{0.5}
% Redefine citation commands to use gray
\let\oldparencite\parencite
\renewcommand{\parencite}[1]{\textcolor{mygray}{\oldparencite{#1}}}
\let\oldtextcite\textcite
\renewcommand{\textcite}[1]{\textcolor{mygray}{\oldtextcite{#1}}}
% Make hyperlinks subtle but active
\usepackage[colorlinks=true, linkcolor=black, urlcolor=blue, citecolor=black]{}
\newcommand{\notrightarrow}{\not\rightarrow}